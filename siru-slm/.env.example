# =============================================================================
# Remote LLM (dataset generation, augmentation, eval baseline, /ideate/scene)
# =============================================================================
# Recommended: Moonshot Kimi API (OpenAI-compatible). Use the OpenAI Python SDK
# with base_url + api_key only — no code changes required.
#
# Get a key: https://platform.moonshot.ai/console/api-keys
#
# Base URL — MUST match where the API key was created (401 if wrong):
#   International (platform.moonshot.ai): https://api.moonshot.ai/v1
#   China (platform.moonshot.cn):         https://api.moonshot.cn/v1
# Diagnose:  python dataset/generate.py --check-auth
# (On failure, the script probes both /v1/models endpoints.)
#
# Model examples (use the exact id from Kimi API Platform docs):
#   kimi-k2.5
#   (older / alternate ids may appear as kimi-k2, etc. — copy from console)
#
# Copy this file to `.env` in the workspace root (parent of `siru-slm/`) and/or `siru-slm/.env`.
# Loading order: workspace `.env` first, then `siru-slm/.env` — duplicate keys keep the workspace value.
# Run:  python dataset/generate.py --check-auth
#
#LLM_API_KEY=your_moonshot_api_key_here
#LLM_API_BASE=https://api.moonshot.ai/v1
#LLM_MODEL=kimi-k2.5
#
# Alternatives (same env vars; swap values):
#   OpenRouter: LLM_API_BASE=https://openrouter.ai/api/v1
#   Together / Groq: use their base URL and model id from their docs
#
# --- Replicate (https://replicate.com) ---
# Use any model page id, e.g. meta/meta-llama-3-70b-instruct — see model schema for inputs.
# LLM_PROVIDER=replicate
# REPLICATE_API_TOKEN=r8_...
# LLM_MODEL=meta/meta-llama-3-70b-instruct
# (You may use LLM_API_KEY instead of REPLICATE_API_TOKEN if you prefer.)

# Supabase (RAG vector store)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# OpenAI (embeddings for RAG — separate from Kimi; Kimi does not replace this unless you change rag/embed.py)
OPENAI_API_KEY=your_openai_key_here

# Inference (local vLLM + LoRA — Siru SLM)
# Gated HF models (e.g. Meta Llama): accept the license on the model page, create a
# read token at https://huggingface.co/settings/tokens — or run: huggingface-cli login
# HF_TOKEN=hf_...
# MODEL_PATH should match the base you trained on (default training base: Qwen/Qwen2.5-7B-Instruct).
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8001
MODEL_PATH=Qwen/Qwen2.5-7B-Instruct
LORA_PATH=./siru-dialogue-lora

# API (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
SLM_BASE_URL=http://localhost:8001/v1
SLM_MODEL_NAME=siru-dialogue

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
